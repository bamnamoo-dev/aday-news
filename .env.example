# 구글 제미나이 API 키 (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# 지메일 계정 정보
EMAIL_USER=your_email@gmail.com

# 구글 앱 비밀번호 (2단계 인증 후 생성된 16자리 코드)
EMAIL_PASSWORD=your_app_password_here

# 이메일 수신자 (여러 명일 경우 쉼표로 구분)
EMAIL_RECEIVERS=abc@gmail.com,def@naver.com

# 저장 경로 (기본값: reports)
SAVE_DIR=reports
